# PodmanView Configuration
# Copy this file to .env and customize your values
# Or just run the application - .env will be created automatically with defaults

# ===================
# Server Settings
# ===================

# Server address (host:port)
# Default: :80
# Examples: :8080, 0.0.0.0:8080, 127.0.0.1:3000
PODMANVIEW_ADDR=:80

# ===================
# Security Settings
# ===================

# JWT secret key (auto-generated on first run if empty)
# For production, you can generate with: openssl rand -hex 32
# WARNING: Changing this will invalidate all existing sessions!
PODMANVIEW_JWT_SECRET=

# JWT token expiration in seconds
# Default: 86400 (24 hours)
# Min: 60 (1 minute), Max: 31536000 (1 year)
PODMANVIEW_JWT_EXPIRATION=86400

# Disable authentication (for development only!)
# Default: false
# WARNING: Never enable in production!
PODMANVIEW_NO_AUTH=false

# ===================
# Podman Settings
# ===================

# Podman socket path (auto-detect if empty)
# Rootless: /run/user/{uid}/podman/podman.sock
# Rootful: /run/podman/podman.sock
PODMANVIEW_SOCKET=

# ===================
# Logging Settings
# ===================

# Directory for log files
# Default: ./logs
# Logs will be split into:
#   - app.log (all logs)
#   - error.log (errors only)
PODMANVIEW_LOG_DIR=./logs

# Maximum size of each log file in MB before rotation
# Default: 10
# When exceeded, app.log/error.log will be rotated:
#   app.log -> app.log.1 -> app.log.2 -> app.log.3
PODMANVIEW_LOG_MAX_SIZE=10

# Maximum number of rotated log backups to keep
# Default: 3
# Set to 0 to disable backups (only current log kept)
PODMANVIEW_LOG_MAX_BACKUPS=3
